# Конфигурация API ключей для intelligent-trails

# ==============================================================================
# ПОИСК МЕСТ - OpenStreetMap (Overpass API)
# ==============================================================================
# Полностью бесплатный, не требует API ключа
# Используется для: search_places()

# ==============================================================================
# МАРШРУТИЗАЦИЯ - Гибридная система (новое!)
# ==============================================================================
# Система автоматически выбирает лучший сервис для каждого типа транспорта
# Приоритеты:
#   - Пешком:      OSRM → GraphHopper → Mapbox
#   - Авто:        Mapbox (с пробками!) → GraphHopper → OSRM
#   - Велосипед: GraphHopper → OSRM → Mapbox

# ------------------------------------------------------------------------------
# 1. OSRM (бесплатный, без ключа)
# ------------------------------------------------------------------------------
# Лимиты:     Неограниченно (публичный сервер)
# Профили:    foot, driving, bike
# Особенности: Нет общественного транспорта, нет пробок
# Не требует настройки - работает сразу!

# ------------------------------------------------------------------------------
# 2. GraphHopper (рекомендуется для велосипедов)
# ------------------------------------------------------------------------------
# Лимиты:     500 запросов/день (FREE тариф)
# Профили:    foot, car, bike
# Регистрация: https://www.graphhopper.com/dashboard/#/register
# Особенности: Отличные велосипедные маршруты

GRAPHHOPPER_API_KEY=your_graphhopper_api_key_here

# ------------------------------------------------------------------------------
# 3. Mapbox (рекомендуется для авто)
# ------------------------------------------------------------------------------
# Лимиты:     100,000 запросов/месяц (FREE тариф)
# Профили:    walking, driving-traffic, cycling
# Регистрация: https://account.mapbox.com/auth/signup/
# Особенности: Учитывает пробки в режиме driving-traffic!

MAPBOX_API_KEY=your_mapbox_api_key_here

# ==============================================================================
# СТАРЫЙ API - Яндекс (опционально, больше не используется)
# ==============================================================================
# После миграции на гибридную систему, Яндекс API больше не требуется
# (оставлен для обратной совместимости в old endpoint)

YANDEX_API_KEY=

# ==============================================================================
# ИНСТРУКЦИИ ПО НАСТРОЙКЕ
# ==============================================================================

# МИНИМАЛЬНАЯ конфигурация (работает сразу):
# - OSRM уже работает без настроек
# - Подходит для пеших прогулок

# РЕКОМЕНДУЕМАЯ конфигурация:
# 1. Зарегистрируйтесь на GraphHopper (500/день)
# 2. Зарегистрируйтесь на Mapbox (100k/месяц)
# 3. Добавьте ключи в .env
# 4. Получите полный функционал с пробками!

# КАК ПОЛУЧИТЬ API КЛЮЧИ:

# GraphHopper:
# 1. https://www.graphhopper.com/dashboard/#/register
# 2. Подтвердите email
# 3. Dashboard → API Keys → Create New Key
# 4. Скопируйте ключ в GRAPHHOPPER_API_KEY

# Mapbox:
# 1. https://account.mapbox.com/auth/signup/
# 2. Подтвердите email
# 3. Account → Access tokens → Create a token
# 4. Скопируйте токен в MAPBOX_API_KEY

# ==============================================================================
# МОНИТОРИНГ ИСПОЛЬЗОВАНИЯ
# ==============================================================================
# Проверить статистику: GET /routing/stats
# Очистить кеш:      POST /routing/clear_cache
